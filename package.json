{
    "name": "frothers-webpage",
    "version": "1.0.0",
    "description": "Hugo + Typescript + Tina IO project for website",
    "main": "dist/main.js",
    "source": "assets/index.ts",
    "scripts": {
        "start": "run-p start:**",
        "start:hugo": "hugo -d ./dist -w",
        "start:tina": "yarn run tinacms dev",
        "start:webpack": "NODE_OPTIONS='--max-old-space-size=4096' webpack serve --mode development --config webpack.dev.js --hot",
        "preview": "cross-env PORT=8080 run-p preview:**",
        "preview:hugo": "hugo -d ./dist -s site -w -D -F ",
        "preview:webpack": "webpack serve --mode development --config webpack.dev.js --host 0.0.0.0 --public",
        "build": "yarn run build:webpack && yarn run build:tina && yarn run build:hugo",
        "build-local": "yarn run build:webpack && yarn run build:tina --skip-cloud-checks && yarn run build:hugo-local",
        "build:tina": "NODE_OPTIONS=\"--max-old-space-size=4096\" yarn tinacms build",
        "build:preview": "yarn run build:webpack && yarn run build:hugo:preview",
        "build:hugo": "hugo -d ./dist -b $URL",
        "build:hugo-local": "hugo -d ./dist -b frothersfc.com",
        "build:hugo:preview": "yarn run build:hugo -- -D -F",
        "build:webpack": "cross-env NODE_ENV=production NODE_OPTIONS='--max-old-space-size=4096' webpack --config webpack.prod.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/frothers/Frothers-FC.git"
    },
    "author": "Chris Chester",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/frothers/Frothers-FC/issues"
    },
    "homepage": "https://github.com/frothers/Frothers-FC#readme",
    "engines": {
        "node": ">=26.0.0"
    },
    "resolutions": {
        "lodash": "^4.18.0",
        "http-cache-semantics": "^4.1.1",
        "js-cookie": "^3.0.7"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/downloadjs": "^1.4.6",
        "@types/lodash": "4.14.168",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "assets-webpack-plugin": "^7.1.1",
        "axios": "^1.16.1",
        "chart.js": "^4.5.1",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "cross-env": "7.0.3",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "html-webpack-plugin": "^5.6.7",
        "lodash": "^4.18.1",
        "mini-css-extract-plugin": "^2.10.2",
        "node-gyp": "^11.0.0",
        "npm-run-all": "^4.1.5",
        "source-map-loader": "2.0.1",
        "ts-loader": "^9.0.0",
        "typescript": "^6.0.3",
        "webpack": "^5.98.0",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.4",
        "webpack-merge": "^6.0.1"
    },
    "hugo-bin": {
        "buildTags": "extended"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@jpinsonneau/html-to-image": "^1.11.13",
        "@mui/icons-material": "^9.0.1",
        "@mui/material": "^9.0.1",
        "@mui/x-charts": "^9.3.0",
        "@mui/x-date-pickers": "^9.3.0",
        "@tinacms/cli": "^2.4.0",
        "bootstrap": "^5.3.3",
        "downloadjs": "^1.4.7",
        "immutability-helper": "^3.1.1",
        "material-react-table": "^3.2.1",
        "rdndmb-html5-to-touch": "8.0.3",
        "react": "^18.3.1",
        "react-bootstrap": "^2.10.9",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dnd-multi-backend": "8.0.3",
        "react-dnd-touch-backend": "^16.0.1",
        "react-dom": "^18.3.1",
        "recharts": "^2.15.1",
        "tinacms": "^3.8.2"
    }
}
